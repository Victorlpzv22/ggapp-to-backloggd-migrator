{
  "name": "ggapp-to-backloggd-migrator",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "login": "tsx src/cli.ts login",
    "extract": "tsx src/cli.ts extract",
    "import": "tsx src/cli.ts import",
    "migrate": "tsx src/cli.ts migrate",
    "test": "vitest run",
    "test:watch": "vitest",
    "format": "prettier --write \"src/**/*.ts\" \"scripts/**/*.ts\"",
    "format:check": "prettier --check \"src/**/*.ts\" \"scripts/**/*.ts\""
  },
  "dependencies": {
    "chalk": "^5.4.0",
    "commander": "^12.0.0",
    "dotenv": "^16.4.0",
    "playwright": "^1.52.0"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "prettier": "^3.9.4",
    "tsx": "^4.19.0",
    "typescript": "^5.7.0",
    "vitest": "^3.0.0"
  }
}
